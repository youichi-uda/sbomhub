# SBOMHub - Environment variables (development defaults)
#
# DATABASE roles (P0 #2 / Trust Rescue 9.1.1)
#
# DATABASE_URL must point at sbomhub_app (NOBYPASSRLS). The api server will
# refuse to start in production if the connected role has rolbypassrls=true.
#
# MIGRATE_DATABASE_URL must point at sbomhub_migrator (DDL-capable, NOT
# BYPASSRLS). The api server uses it on startup to run migrations, and the
# `migrate` CLI prefers it over DATABASE_URL.
#
# These URLs are passed verbatim to lib/pq (Go) and golang-migrate, which use
# net/url to parse the userinfo segment. If your password contains any of
# `@ : / # ? & % +` etc. (any RFC 3986 reserved char), you MUST URL-encode it
# before placing it here, otherwise the host portion will be mis-parsed.
# Examples:
#   p@ss      -> p%40ss
#   a/b:c     -> a%2Fb%3Ac
#   secret#1  -> secret%231
# install.sh generates passwords via `openssl rand -hex 16`, which is
# URL-safe by construction, so the values it writes need no further escaping.
#
# Host selection (compose vs. local dev):
#   - For `go run ./cmd/server` against `docker compose up -d postgres`, use
#     `localhost` as below — the values are read by the Go process running on
#     the host machine.
#   - For `docker compose up -d` (api inside a container), the value below
#     overrides the docker-compose default (which uses the internal hostname
#     `postgres`). Either change `localhost` to `postgres` here, or run
#     `./install.sh` which rewrites both URLs to point at `postgres` and
#     substitutes a fresh hex password. Without one of those two steps the
#     api container will try to dial localhost inside the container and fail.
#
# To inject a production-grade URL with URL-encoded password, simply replace
# the line below with the full URL — docker-compose will pick it up via
# `${DATABASE_URL:-...}` and forward it verbatim to the api container.
DATABASE_URL=postgres://sbomhub_app:sbomhub_app_dev@localhost:5432/sbomhub?sslmode=disable
MIGRATE_DATABASE_URL=postgres://sbomhub_migrator:sbomhub_migrator_dev@localhost:5432/sbomhub?sslmode=disable

# Passwords consumed by docker-compose to bootstrap the two roles in
# postgres via apps/api/cmd/migrate/init.sh. Override these in production.
# These are interpolated by docker-compose as plain values (no URL escaping),
# so they may contain any character that PostgreSQL accepts in a CREATE ROLE
# PASSWORD literal. If you want the same password to also work when injected
# into DATABASE_URL / MIGRATE_DATABASE_URL above via the compose fallback
# (`postgres://sbomhub_app:${APP_PASSWORD}@postgres:5432/...`), keep it
# URL-safe (alphanumerics / `-` / `.` / `_` / `~`) or set DATABASE_URL /
# MIGRATE_DATABASE_URL above explicitly with the URL-encoded form.
MIGRATOR_PASSWORD=sbomhub_migrator_dev
APP_PASSWORD=sbomhub_app_dev

REDIS_URL=redis://localhost:6379
PORT=8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NVD_API_KEY=

# APP_ENV: development | staging | production
# In any value other than "development", the api refuses to start if the
# DATABASE_URL role has rolbypassrls=true.
APP_ENV=development

# Encryption key (P0 #5 / #7 / Trust Rescue 9.2).
#
# REQUIRED whenever APP_ENV is anything other than "development".
# The api will refuse to start if this is unset, a known default placeholder
# (changeme, default, test, your-encryption-key-here, ...) or shorter than
# 32 bytes (AES-256).
#
# Generate a fresh key per deployment with one of:
#   openssl rand -base64 32
#   openssl rand -hex 32
#
# NOTE: the Go server reads ENCRYPTION_KEY (no SBOMHUB_ prefix). docker-compose
# also looks for ENCRYPTION_KEY and aborts startup if it is missing.
ENCRYPTION_KEY=

# LLM provider (BYOK only in OSS, see planning/LLM_PROVIDER_DESIGN.md).
# Leave empty to disable AI features (VEX triage / CRA draft / METI prefill).
# Supported: openai | anthropic | gemini | ollama | azure
SBOMHUB_LLM_PROVIDER=
SBOMHUB_LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=

# Waitlist form receiver (Formspree / Tally / Basin endpoint).
# Leave empty to fall back to mailto:hello@sbomhub.app on the landing page.
NEXT_PUBLIC_WAITLIST_FORM_URL=
