# ===========================================
# SBOMHub Backend Configuration
# ===========================================

# Core Settings
PORT=8080
DATABASE_URL=postgres://sbomhub:sbomhub@localhost:5432/sbomhub?sslmode=disable
REDIS_URL=redis://localhost:6379

# Deployment mode (codex-r18 P1): APP_ENV is the canonical variable, matching
# docker-compose.yml and the startup guards in cmd/server/main.go. The legacy
# ENVIRONMENT variable still works as a fallback when APP_ENV is unset, but new
# deployments should set APP_ENV only.
APP_ENV=development

# External APIs
NVD_API_KEY=
BASE_URL=http://localhost:3000

# Security
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# ===========================================
# Clerk Authentication (SaaS mode only)
# Leave empty for self-hosted mode
# ===========================================
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ===========================================
# Lemon Squeezy Billing (SaaS mode only)
# Leave empty to disable billing
# ===========================================
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_TEAM_VARIANT_ID=
