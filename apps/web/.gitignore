# Next.js build output
/.next/
/out/

# Node / pnpm
/node_modules/

# Build artefacts
/build/
/dist/

# TypeScript incremental build cache (regenerated by every `tsc` /
# `next build`). Historically a tracked `apps/web/tsconfig.tsbuildinfo`
# produced PR-time diff noise — M13-5 (#91) `git rm --cached`'d the
# tracked copy so future regenerations stay local. The `*.tsbuildinfo`
# glob covers `tsconfig.tsbuildinfo` and any per-project variants. Note
# that `next-env.d.ts` is intentionally NOT ignored: Next.js documents
# it as a tracked file, and the project's typecheck relies on its
# triple-slash directives being present at clone time.
*.tsbuildinfo

# Playwright (M8 #67) — keep test artefacts out of git;
# CI uploads them as a build artefact on failure instead.
/test-results/
/playwright-report/
/playwright/.cache/

# OS / editor
.DS_Store
*.log
