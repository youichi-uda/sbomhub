# Private documents (not for public repo)
/private/
/.claude/

# Internal documents (kept in sbomhub-internal repo)
/docs/articles/
/docs/STATUS.md

# Test/temp files
/test-sbom*.json
/nul
docker_info.txt
docker_ps.txt

# Playwright MCP screenshots (development only)
/.playwright-mcp/

# Playwright browser profile (session persistence)
/.playwright-profile/

# Dependencies
node_modules/
.pnpm-store/
vendor/

# Build outputs
dist/
build/
.next/
out/
bin/
*.exe

# Environment files
.env
.env.local
.env.*.local
# M10-4 #72: goreleaser before.hooks copies .env.example -> default.env.example
# at release time so the GitHub asset name and SHA256SUMS entry stay aligned
# (GitHub release assets cannot start with a dot). The copy is build-only.
default.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/
coverage.out
coverage.html
*.test

# Playwright test results
test-results/
playwright-report/

# Temporary files
tmp/
temp/

# Misc
*.pem
.turbo

# Enterprise self-host (M4-6): actual secrets and backups must never be committed.
# Only the *.sample files under docker/secrets.example/ are tracked.
/docker/secrets/
/docker/backups/

# GoReleaser output (M5-2 / #54): llm-bench release archives + checksums.
# CI uploads these to the GitHub Release; nothing in /dist/ belongs in git.
/dist/
